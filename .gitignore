a.out
**/a.out

# ============================================
# ROBUST SOLUTION: Ignore ALL executables in C++ folders
# ============================================
# This ignores any file without an extension in C++ directory
# Matches: whileLoop, squarePattern, 01_prblm, etc.
# Does NOT match: file.cpp, file.h, README.md, etc.

# Pattern 1: Files ending with common patterns
C++/**/*Loop
C++/**/*loop  
C++/**/*Pattern
C++/**/*pattern
C++/**/*_prblm
C++/**/*_problem
C++/**/*_test
C++/**/*Stmt
C++/**/*stmt

# Pattern 2: Specific known executables
C++/**/whileLoop
C++/**/forLoop
C++/**/doWhileLoop
C++/**/nestedLoop
C++/**/squarePattern
C++/**/trianglePattern
C++/**/pyramidPattern
C++/**/diamondPattern
C++/**/ifElse
C++/**/if_else_if
C++/**/ternaryStmt
C++/**/calculator
C++/**/variables
C++/**/inputs
C++/**/arithmetic
C++/**/relational
C++/**/logical
C++/**/unary
C++/**/implicitTypeCasting
C++/**/explicitTypeCasting
C++/**/FirstCode

# Pattern 3: Number-based problem files
C++/**/[0-9][0-9]_prblm
C++/**/[0-9][0-9]_problem

