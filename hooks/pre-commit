#!/bin/bash

# 🎣 Pre-commit hook - Smart Executable Detector
# 🛡️ Prevents accidentally committing compiled executables
# 🤖 Interactive: Asks what to do if executables are found

# 🎨 Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m' # No Color

echo ""
echo -e "${CYAN}╔════════════════════════════════════════════════════════════════╗${NC}"
echo -e "${CYAN}║${NC}  ${BOLD}🔍 Smart Pre-Commit Check${NC}                                  ${CYAN}║${NC}"
echo -e "${CYAN}╚════════════════════════════════════════════════════════════════╝${NC}"
echo ""

# 📋 Get list of staged files (files about to be committed)
staged_files=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$staged_files" ]; then
    echo -e "${YELLOW}⚠️  No files staged for commit${NC}"
    echo ""
    exit 0
fi

echo -e "${CYAN}📂 Checking staged files...${NC}"
echo ""

# 🔍 Check for executables in staged files
executables=()
source_files=()

for file in $staged_files; do
    # Skip if file doesn't exist (deleted files)
    if [ ! -f "$file" ]; then
        continue
    fi
    
    # Check if file is in C++ directory
    if [[ ! "$file" =~ ^C\+\+/ ]]; then
        continue
    fi
    
    # Get file extension
    extension="${file##*.}"
    filename=$(basename "$file")
    
    # Check if file has no extension (potential executable)
    if [[ "$filename" != *.* ]]; then
        # Check if it's actually executable
        if [ -x "$file" ]; then
            executables+=("$file")
        fi
    fi
    
    # Track source files
    if [[ "$extension" == "cpp" ]] || [[ "$extension" == "h" ]] || [[ "$extension" == "hpp" ]]; then
        source_files+=("$file")
    fi
done

# ✅ If no executables found, proceed
if [ ${#executables[@]} -eq 0 ]; then
    echo -e "${GREEN}✅ No executables found in staged files${NC}"
    echo -e "${GREEN}✅ All checks passed! 🎉${NC}"
    echo ""
    exit 0
fi

# 🚨 Executables found! Show warning
echo -e "${RED}╔════════════════════════════════════════════════════════════════╗${NC}"
echo -e "${RED}║${NC}  ${BOLD}⚠️  WARNING: Executables Detected! 🚨${NC}                      ${RED}║${NC}"
echo -e "${RED}╚════════════════════════════════════════════════════════════════╝${NC}"
echo ""
echo -e "${YELLOW}🔥 The following executable files are about to be committed:${NC}"
echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

for exe in "${executables[@]}"; do
    echo -e "  ${RED}❌${NC} $exe"
    
    # Check if corresponding .cpp exists
    cpp_file="${exe}.cpp"
    if [ -f "$cpp_file" ]; then
        echo -e "     ${CYAN}🔗 Compiled from:${NC} $cpp_file"
    fi
done

echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""

# 🤖 Interactive prompt
echo -e "${CYAN}╔════════════════════════════════════════════════════════════════╗${NC}"
echo -e "${CYAN}║${NC}  ${BOLD}🤔 What would you like to do?${NC}                              ${CYAN}║${NC}"
echo -e "${CYAN}╚════════════════════════════════════════════════════════════════╝${NC}"
echo ""
echo -e "${MAGENTA}  [1]${NC} ${GREEN}Auto-fix${NC} - Unstage executables and add to .gitignore ${BOLD}(Recommended)${NC}"
echo -e "${MAGENTA}  [2]${NC} ${YELLOW}Manual${NC} - I'll fix it myself (abort commit)"
echo -e "${MAGENTA}  [3]${NC} ${RED}Force${NC} - Commit anyway (not recommended!)"
echo ""
echo -ne "${CYAN}👉 Enter your choice [1/2/3]:${NC} "

# Read user input
read -r choice

echo ""

case $choice in
    1)
        # 🤖 Auto-fix: Unstage executables and add to .gitignore
        echo -e "${GREEN}╔════════════════════════════════════════════════════════════════╗${NC}"
        echo -e "${GREEN}║${NC}  ${BOLD}🤖 Auto-fixing...${NC}                                          ${GREEN}║${NC}"
        echo -e "${GREEN}╚════════════════════════════════════════════════════════════════╝${NC}"
        echo ""
        
        for exe in "${executables[@]}"; do
            # Unstage the file
            echo -e "${CYAN}📤 Unstaging:${NC} $exe"
            git reset HEAD "$exe" 2>/dev/null
            
            # Check if already in .gitignore
            if ! grep -qF "$exe" .gitignore; then
                echo -e "${GREEN}📝 Adding to .gitignore:${NC} $exe"
                echo "$exe" >> .gitignore
            else
                echo -e "${YELLOW}ℹ️  Already in .gitignore:${NC} $exe"
            fi
        done
        
        echo ""
        echo -e "${GREEN}✅ Auto-fix complete!${NC}"
        echo ""
        echo -e "${CYAN}📋 Summary:${NC}"
        echo -e "  ${GREEN}✓${NC} Executables unstaged"
        echo -e "  ${GREEN}✓${NC} Added to .gitignore"
        echo -e "  ${GREEN}✓${NC} Source files (.cpp) still staged"
        echo ""
        echo -e "${YELLOW}💡 Next steps:${NC}"
        echo -e "  1. Review changes: ${CYAN}git status${NC}"
        echo -e "  2. Commit again: ${CYAN}git commit${NC}"
        echo ""
        
        # Check if .gitignore was modified
        if git diff --name-only | grep -q ".gitignore"; then
            echo -e "${MAGENTA}📌 Note:${NC} .gitignore was updated. You may want to commit it:"
            echo -e "   ${CYAN}git add .gitignore${NC}"
            echo -e "   ${CYAN}git commit -m \"Update .gitignore to exclude executables\"${NC}"
            echo ""
        fi
        
        exit 1  # Abort current commit (user needs to commit again)
        ;;
        
    2)
        # 🛠️ Manual fix
        echo -e "${YELLOW}╔════════════════════════════════════════════════════════════════╗${NC}"
        echo -e "${YELLOW}║${NC}  ${BOLD}🛠️  Manual Fix Mode${NC}                                        ${YELLOW}║${NC}"
        echo -e "${YELLOW}╚════════════════════════════════════════════════════════════════╝${NC}"
        echo ""
        echo -e "${CYAN}💡 To fix manually:${NC}"
        echo ""
        echo -e "${MAGENTA}Option 1:${NC} Unstage specific files"
        for exe in "${executables[@]}"; do
            echo -e "  ${CYAN}git reset HEAD $exe${NC}"
        done
        echo ""
        echo -e "${MAGENTA}Option 2:${NC} Add to .gitignore"
        for exe in "${executables[@]}"; do
            echo -e "  ${CYAN}echo \"$exe\" >> .gitignore${NC}"
        done
        echo ""
        echo -e "${MAGENTA}Option 3:${NC} Use helper script"
        echo -e "  ${CYAN}./scripts/update_gitignore.sh${NC}"
        echo ""
        echo -e "${RED}🚫 Commit aborted!${NC}"
        echo -e "${YELLOW}Fix the issues and try again 🔧${NC}"
        echo ""
        exit 1
        ;;
        
    3)
        # ⚠️ Force commit (not recommended)
        echo -e "${RED}╔════════════════════════════════════════════════════════════════╗${NC}"
        echo -e "${RED}║${NC}  ${BOLD}⚠️  Force Commit${NC}                                           ${RED}║${NC}"
        echo -e "${RED}╚════════════════════════════════════════════════════════════════╝${NC}"
        echo ""
        echo -e "${YELLOW}⚠️  Are you sure? This will commit executables to Git!${NC}"
        echo -ne "${RED}Type 'YES' to confirm:${NC} "
        read -r confirm
        echo ""
        
        if [ "$confirm" = "YES" ]; then
            echo -e "${YELLOW}⚠️  Proceeding with commit (executables included)...${NC}"
            echo ""
            exit 0  # Allow commit
        else
            echo -e "${GREEN}✅ Commit aborted (smart choice!)${NC}"
            echo ""
            exit 1
        fi
        ;;
        
    *)
        # Invalid choice
        echo -e "${RED}❌ Invalid choice!${NC}"
        echo -e "${RED}🚫 Commit aborted!${NC}"
        echo ""
        exit 1
        ;;
esac
