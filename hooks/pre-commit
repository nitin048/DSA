#!/bin/bash

# 🎣 Pre-commit hook to check for untracked executables
# 🛡️ This prevents accidentally committing compiled files

# 🎨 Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
NC='\033[0m' # No Color

echo ""
echo -e "${CYAN}🔍 Scanning for untracked executables...${NC}"

# 📂 Find untracked files in C++ directory
untracked=$(git ls-files --others --exclude-standard C++/)

if [ -z "$untracked" ]; then
    echo -e "${GREEN}✅ All clear! No untracked files in C++ directory${NC}"
    echo -e "${GREEN}🎯 Ready to commit!${NC}"
    echo ""
    exit 0
fi

# 🔎 Check for executables
executables_found=false

for file in $untracked; do
    # ⏭️ Skip files with common source extensions
    if [[ "$file" =~ \.(cpp|h|hpp|md|txt)$ ]]; then
        continue
    fi
    
    # 🔍 Check if file is executable or has no extension
    if [ -x "$file" ] || [[ ! "$file" =~ \. ]]; then
        if [ "$executables_found" = false ]; then
            echo ""
            echo -e "${RED}╔════════════════════════════════════════════════════════════════╗${NC}"
            echo -e "${RED}║${NC}  ${BOLD}⚠️  WARNING: Untracked Executables Found! 🚨${NC}              ${RED}║${NC}"
            echo -e "${RED}╚════════════════════════════════════════════════════════════════╝${NC}"
            echo ""
            echo -e "${YELLOW}📋 The following executable files are not in .gitignore:${NC}"
            echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
            executables_found=true
        fi
        
        basename=$(basename "$file")
        echo -e "  ${RED}❌${NC} $file"
        
        # 🔗 Check if corresponding .cpp exists
        cpp_file="${file}.cpp"
        if [ -f "$cpp_file" ]; then
            echo -e "     ${CYAN}🔗 Compiled from:${NC} $cpp_file"
        fi
    fi
done

if [ "$executables_found" = true ]; then
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo -e "${CYAN}💡 ${BOLD}How to fix this:${NC}"
    echo ""
    echo -e "  ${MAGENTA}🎯 Option 1:${NC} Add to .gitignore manually"
    echo -e "    ${GREEN}💻 echo \"C++/**/<filename>\" >> .gitignore${NC}"
    echo ""
    echo -e "  ${MAGENTA}🎯 Option 2:${NC} Run helper script"
    echo -e "    ${GREEN}💻 ./scripts/check_executables.sh${NC}"
    echo ""
    echo -e "  ${MAGENTA}🎯 Option 3:${NC} Auto-update .gitignore"
    echo -e "    ${GREEN}💻 ./scripts/update_gitignore.sh${NC}"
    echo ""
    echo -e "${RED}╔════════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${RED}║${NC}  ${BOLD}🚫 COMMIT BLOCKED! 🛑${NC}                                       ${RED}║${NC}"
    echo -e "${RED}║${NC}  ${YELLOW}⚠️  Fix the issues above and try again 🔧${NC}                  ${RED}║${NC}"
    echo -e "${RED}╚════════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    exit 1
fi

echo -e "${GREEN}✅ All checks passed! 🎉${NC}"
echo -e "${GREEN}🚀 Proceeding with commit...${NC}"
echo ""
exit 0
